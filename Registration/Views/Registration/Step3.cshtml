@model Registration.Models.RegistrationStep3ViewModel

@{
    ViewData["Title"] = "Rejestracja - Krok 3";
}

<div class="card shadow-sm mx-auto" style="max-width: 600px;">
    <div class="card-body">
        <h3 class="text-center mb-4">Krok 3 – Zgody</h3>

        <form method="post">
            <input type="hidden" asp-for="ResumeToken" />
            <input type="hidden" asp-for="IsMinor" />

            @if (Model.IsMinor)
            {
                <div class="mb-3">
                    <label class="form-label">Imię rodzica</label>
                    <input asp-for="ParentName" class="form-control" />
                    <span asp-validation-for="ParentName" class="text-danger"></span>
                </div>
            }

            <div class="form-check mb-3">
                <input asp-for="ConsentGiven" class="form-check-input" type="checkbox" />
                <label class="form-check-label">Akceptuję warunki uczestnictwa</label>
            </div>

            <span asp-validation-for="ConsentGiven" class="text-danger"></span>

            <button type="submit" class="btn btn-success w-100">Zakończ</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
